# =============================================================================
# FlowScope configuration. Copy to `.env` and fill in keys you have.
# EVERY key is optional — the dashboard runs with zero keys using free,
# no-auth sources (Yahoo options, SEC EDGAR, USAspending, Senate disclosures).
# Adding keys unlocks more sources and better failover. See README "API keys".
# =============================================================================

# --- Options flow (adding these greatly improves coverage + greeks) ----------
# Finnhub: free, no credit card. https://finnhub.io/register
#   Unlocks: options chains, insider tx, congressional trades, news, earnings.
FINNHUB_API_KEY=

# Tradier sandbox: free, no credit card. https://developer.tradier.com/
#   Unlocks: full options chains WITH greeks + 15-min delayed quotes.
TRADIER_TOKEN=
TRADIER_ENV=sandbox          # sandbox | production

# --- Optional extra catalyst / failover sources ------------------------------
# Financial Modeling Prep: free tier. https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=

# Alpha Vantage: free. https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=

# NewsAPI: free dev tier. https://newsapi.org/register
NEWSAPI_KEY=

# Quiver Quantitative (congress / gov contracts / lobbying). https://www.quiverquant.com/
QUIVER_API_KEY=

# --- SEC EDGAR requires a descriptive User-Agent (no key). Set your email. ----
SEC_USER_AGENT=FlowScope/1.0 (ryanwallac33@gmail.com)

# --- Engine tuning -----------------------------------------------------------
REFRESH_INTERVAL_SECONDS=300   # how often the flow scan re-runs
UNIVERSE_REFRESH_HOURS=24      # how often to re-pull S&P500 / NDX100 membership
MAX_TICKERS_PER_CYCLE=120      # cap symbols scanned per cycle (rate-limit safety)
HTTP_TIMEOUT_SECONDS=20
LOG_LEVEL=INFO
